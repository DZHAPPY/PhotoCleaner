<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_pressed="true">
        <shape android:shape="rectangle">
            <corners android:radius="12dp" />
            <gradient
                android:angle="315"
                android:endColor="#169A48"
                android:startColor="#1FB85A" />
        </shape>
    </item>
    <item>
        <shape android:shape="rectangle">
            <corners android:radius="12dp" />
            <gradient
                android:angle="315"
                android:endColor="#16A34A"
                android:startColor="@color/accent_keep" />
        </shape>
    </item>
</selector>
